root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# C# 用 4 空格
[*.cs]
indent_size = 4

# .NET 專案/設定檔
[*.{csproj,props,targets,json}]
indent_size = 2

# Markdown 容許行尾空白(換行語意)
[*.md]
trim_trailing_whitespace = false
