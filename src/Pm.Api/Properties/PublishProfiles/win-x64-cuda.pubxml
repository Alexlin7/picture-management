<?xml version="1.0" encoding="utf-8"?>
<!--
  win-x64 自包含單檔發版設定 —— CUDA flavor(僅 NVIDIA,目標 24H2 以下的 NVIDIA 使用者)。
  用法:dotnet publish src/Pm.Api -p:PublishProfile=win-x64-cuda
  產物:同 win-x64,但 Pm.Ml 綁 Microsoft.ML.OnnxRuntime.Gpu({CPU,CUDA,TensorRT} EP)。
  installer 較肥(bundle cuDNN/TensorRT native)屬正常;執行機另需相容的 CUDA / cuDNN runtime。
  註:CUDA 推論需 NVIDIA GPU,CI runner 無 GPU → 僅 build+publish 驗證,不驗推論。
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <PublishDir>bin\Release\net10.0\publish\</PublishDir>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <InferenceFlavor>cuda</InferenceFlavor>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <PublishReadyToRun>true</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>
