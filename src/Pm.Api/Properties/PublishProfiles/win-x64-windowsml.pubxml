<?xml version="1.0" encoding="utf-8"?>
<!--
  win-x64 自包含單檔發版設定 —— Windows ML flavor(主力,目標 Windows 11 24H2 / build 26100+)。
  用法:dotnet publish src/Pm.Api -p:PublishProfile=win-x64-windowsml
  產物:同結構,但 Pm.Ml/Pm.Api 為 Windows TFM(net10.0-windows10.0.26100.0),綁
  Microsoft.Windows.AI.MachineLearning —— ORT 由 OS 共享,vendor EP(TensorRT-RTX / OpenVINO /
  MIGraphX / NPU)由 ExecutionProviderCatalog runtime 下載,故 installer 最小。
  註:① 硬體 EP 需 Win11 24H2(build 26100)+;② 首次取得 EP 需連網;③ CI runner 與本機無法驗
  runtime EP 列舉/註冊 → 僅 build+publish 驗證。
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <PublishDir>bin\Release\net10.0-windows10.0.26100.0\publish\</PublishDir>
    <TargetFramework>net10.0-windows10.0.26100.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <InferenceFlavor>windowsml</InferenceFlavor>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <PublishReadyToRun>true</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>
