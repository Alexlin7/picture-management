{
  "ConnectionStrings": {
    "Pm": "Data Source=pm.sqlite"
  },
  "Thumbnails": {
    "Dir": "thumbs",
    "MaxEdge": 512
  },
  "Inference": {
    "Wd14": {
      "Enabled": false,
      "Backend": "directml",
      "ModelDir": "models/wd14",
      "GeneralThreshold": 0.35,
      "CharacterThreshold": 0.85
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
